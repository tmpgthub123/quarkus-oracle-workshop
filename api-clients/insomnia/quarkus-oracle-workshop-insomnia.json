      "_id": "pf_book_service_proto",
      "_type": "proto_file",
      "parentId": "pd_proto_proto",
      "name": "book_service.proto",
      "protoText": "syntax = \"proto3\";\n\npackage com.enlight.demo.book;\n\noption java_package = \"com.enlight.demo.book.grpc\";\noption java_outer_classname = \"BookServiceProto\";\noption java_multiple_files = true;\n\nservice BookService {\n    // Simple unary method used in workshop as gRPC alternative to REST GET /api/books/{id}.\n    rpc GetBookById (GetBookByIdRequest) returns (BookReply);\n}\n\nmessage GetBookByIdRequest {\n    // The book ID in DB (same id as REST /api/books/{id}).\n    int64 id = 1;\n}\n\nmessage BookReply {\n    int64 id = 1;\n    string title = 2;\n    string author = 3;\n    string isbn = 4;\n    string category = 5;\n}\n",
      "created": 1732473600000,
      "modified": 1732473600000
    },
